      \"\u81ED\u7AE0\u9B5A\" \u5435\u67B6\tL\t\r\n1\t28\t\u5E97\u9577\tBossOctopus_04\tBossOctopus_DialogueBox_01\t\u4F60\u8AAA\u8AB0
      \"\u81ED\u7AE0\u9B5A\" \u554A!\u81ED\u5C0F\u9B3C\tR\t\r\n1\t29\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u5E97\u9577!\tL\t\r\n1\t30\t\u5E97\u9577\tBossOctopus_00\tBossOctopus_DialogueBox_01\t\u6211\u77E5\u9053\u4E86\uFF0C\u6211\u4E0D\u8DDF\u4ED6\u5435\u4E86\tR\t\r\n1\t31\t\u771F\u767D\tWhite_00\tWhite_DialogueBox_01\t(\u5077\u7B11)\tR\t\r\n1\t32\t\u7D05\u54B2\tHONGXIAO_03\tHONGXIAO_DialogueBox_00\t\u771F\u767D...\tL\t\r\n1\t33\t\u771F\u767D\tWhite_00\tWhite_DialogueBox_01\t\u62B1\u6B49\tR\t\r\n1\t34\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u6240\u4EE5\u5E97\u9577\u4F60\u600E\u9EBC\u4E86\uFF0C\u4ECA\u5929\u4E00\u76F4\u5F85\u5728\u8FA6\u516C\u5BA4\u88E1\u4E0D\u51FA\u4F86\tL\t\r\n1\t35\t\u5E97\u9577\tBossOctopus_00\tBossOctopus_DialogueBox_01\t\u554A\u2026\u4E5F\u6C92\u4EC0\u9EBC\u5C31\u5728\u7169\u60F1\u4E00\u4E9B\u4E8B\u60C5\u3002\tR\t\r\n1\t36\t\u771F\u767D\tWhite_00\tWhite_DialogueBox_00\t\u771F\u96E3\u5F97\u7AE0\u9B5A\u4E5F\u6703\u7169\u60F1\uFF0C\u770B\u4F86\u771F\u7684\u75C5\u4E86\tL\t\r\n1\t37\t\u5E97\u9577\tBossOctopus_00\tBossOctopus_DialogueBox_01\t\u8AAA\u7684\u6211\u597D\u50CF\u6C92\u7169\u60F1\u7684\u6A23\u5B50\uFF0C\\n\u5C0F\u5B69\u5B50\u600E\u9EBC\u6703\u660E\u767D\u5927\u4EBA\u7684\u7169\u60F1\tR\t\r\n1\t38\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u7A76\u7ADF\u662F\u751A\u9EBC\u6A23\u7684\u5927\u4E8B\u8B93\u5E97\u9577\u5982\u6B64\u61CA\u60F1\tL\t\r\n1\t39\t\u5E97\u9577\tBossOctopus_00\tBossOctopus_DialogueBox_01\t\u4E5F\u6C92\u4EC0\u9EBC\uFF0C\u53EA\u662F\u4E4B\u524D\u60F3\u505A\u4F46\u6C92\u505A\u7684\u4E8B\u5DEE\u4E0D\u591A\u80FD\u57F7\u884C\u4E86\tR\t\r\n1\t40\t\u771F\u767D\tWhite_01\tWhite_DialogueBox_00\t\u641E\u7684\u90A3\u9EBC\u795E\u79D8\uFF0C\u5230\u5E95\u662F\u751A\u9EBC\u4E8B\u60C5!\tL\t\r\n1\t41\t\u5E97\u9577\tBossOctopus_00\tBossOctopus_DialogueBox_01\t\u7B49\u4ECA\u5929\u71DF\u696D\u7D50\u675F\u4F60\u5011\u4F86\u8FA6\u516C\u5BA4\u518D\u8AAA\tR\t\r\n1\t42\t\u771F\u767D\tWhite_01\tWhite_DialogueBo