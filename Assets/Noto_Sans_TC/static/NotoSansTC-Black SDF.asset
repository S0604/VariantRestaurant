      E \" \u5C31\u80FD\u4F7F\u7528\tL\t\r\n5\t1\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u8207\u70F9\u98EA\u53F0\u4E92\u52D5\u5F8C\u5C07\u9032\u884C\u6599\u7406\u88FD\u4F5C\uFF0C\\n\u88FD\u4F5C\u904E\u7A0B\u4E26\u4E0D\u8907\u96DC\u53EA\u9700\u7167\u8457\u70F9\u98EA\u53F0\\n\u4E0B\u65B9\u7684\u7BAD\u982D\u6309\u4E0B\u5C0D\u61C9\u7684\u6848\u4EF6\u5C31\u884C\u56C9!\tL\t\r\n5\t2\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u4E0A
      = W\u3001\u4E0B = S\\n\u5DE6 = A\u3001\u53F3 = D \tL\t\r\n6\t1\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u606D\u559C\u4F60\u6210\u529F\u88FD\u4F5C\u4E00\u9053\u6599\u7406\uFF0C\\n\u770B\u8D77\u4F86\u5341\u5206\u7684\u7F8E\u5473\u5462!\tL\t\r\n6\t2\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u88FD\u4F5C\u597D\u7684\u6599\u7406\u5C07\u6703\u5728\u4E0B\u65B9\u9910\u76E4\u4E2D\u986F\u793A\tL\t\r\n6\t3\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u8981\u6CE8\u610F\u9910\u76E4\u6700\u591A\u53EA\u80FD\u653E\u6700\u591A2\u500B\u7269\u54C1\u5594!\tL\t\r\n6\t4\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u8981\u8A66\u60F3\u6E05\u6473\u9910\u76E4\u7684\u8A71\uFF0C\u53EF\u4EE5\u5230\u5783\u573E\u6876\u8655\u7406\tL\t\r\n6\t5\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u63A5\u4E0B\u4F86\u8B93\u6211\u5011\u5230\u6CB9\u70B8\u934B\u88FD\u4F5C\u85AF\u689D\u5427!\tL\t\r\n6_1\t1\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u554A\u555E\u555E!\u6599\u7406\u88FD\u4F5C\u5931\u6557\uFF0C\u53EA\u80FD\u628A\u5979\u8655\u7406\u6389\u4E86\u5462!\tL\t\r\n6_1\t2\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u5230\u5783\u573E\u6876\u524D\u5C07\u5B83\u8655\u7406\u6389\u5427!\tL\t\r\n6_2\t1\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u5728\u5783\u573E\u6876\u524D\u6309\u4E0B\"E\"\u5C31\u80FD\u4E1F\u68C4\u9910\u76E4\u4E0A\u7684\u6240\u6709\u6771\u897F\tL\t\r\n6_2\t2\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u8981\u6CE8\u610F!\\n
      \"\u662F\u4E00\u53E3\u6C23\u5C07\u9910\u76E4\u4E0A\u7684\u6771\u897F\u90FD\u4E1F\u68C4\u88FD\u5783\u573E\u6876\"\tL\t\r\n6_3\t1\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u7D42\u65BC\u5C07\u5783\u573E\u8655\u7406\u597D\u4E86\uFF0C\\n\u8B93\u6211\u5011\u7E7C\u7E8C\u5617\u8A66\u88FD\u4F5C\u51FA\u6599\u7406\u5427\tL\t\r\n6_4\t1\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u9910\u76E4\u6EFF\u4E86\uFF0C\u9019\u6A23\u7121\u6CD5\u518D\u62FF\u53D6\u65B0\u7684\u7269\u54C1\uFF0C\\n\u9700\u8981\u5230\u5783\u573E\u6876\u524D\u79FB\u9664\u9910\u76E4\u4E0A\u7684\u7269\u54C1\u624D\u80FD\u7372\u53D6\u65B0\u7269\u54C1\tL\t\r\n7\t1\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u85AF\u689D\u4E5F\u662F\u540C\u6A23\u7684\u4F5C\u6CD5\uFF0C\\n\u8A66\u8A66\u505A\u51FA\u4E00\u4EFD\u85AF\u689D\u5427!\tL\t\r\n8\t1\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u606D\u559C\u59B3\u5B78\u6703\u5982\u4F55\u88FD\u4F5C\u6599\u7406\u4E86\tL\t\r\n8\t2\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u63A5\u4E0B\u4F86\uFF0C\u8B93\u6211\u5011\u8A66\u8A66\u4F9D\u7167\u9867\u5BA2\u7684\\n\u9700\u6C42\u4E0A\u5C0D\u61C9\u7684\u9910\u9EDE\u5427!\tL\t\r\n8\t3\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u6211\u525B\u525B\u5F9E\u5916\u9762\u8ACB\u4F86\u4E00\u4E9B\u8DEF\u4EBA\u4F5C\u70BA\u6211\u5011\u7DF4\u7FD2\u7684\u5C0D\u8C61\tL\t\r\n8\t4\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u8B93\u6211\u5011\u770B\u770B\u4ED6\u5011\u9700\u8981\u751A\u9EBC\u5427!\tL\t\r\n9\t1\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u9867\u5BA2\u5230\u6536\u9280\u53F0\u6642\uFF0C\u6703\u5728\u756B\u9762\u5DE6\u4E0B\u65B9\u986F\u793A\u4ED6\u7684\u8A02\u55AE\tL\t\r\n9\t2\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u8981\u6CE8\u610F\u6536\u9280\u53F0\u6700\u591A\u53EA\u80FD\u63A5\u56DB\u500B\u8A02\u55AE\uFF0C\u800C\u5728\u6536\u9280\u6AAF\u524D\u7B2C\u4E00\u4F4D\u9867\u5BA2\u7684\u8A02\u55AE\u6703\u9AD8\u91CF\u986F\u793A\u5594!\tL\t\r\n9\t3\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u53EA\u8981\u4F60\u7684\u9910\u76E4\u4E2D\u6709\u8207\u7B2C\u4E00\u4F4D\u9867\u5BA2\u8A02\u55AE\u76F8\u540C\u7684\u6599\u7406\uFF0C\u5728\u6536\u9280\u6AAF\u524D\u6309\u4E0B\"
      E \"\u5C31\u80FD\u5C07\u8A72\u6599\u7406\u7D66\u4E88\u9019\u4F4D\u9867\u5BA2\tL\t\r\n9\t4\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u8A66\u8A66\u5B8C\u6210\u7B2C\u4E00\u4F4D\u9867\u5BA2\u7684\u8A02\u55AE\u5427!\tL\t\r\n10\t1\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u9019\u4F4D\u9867\u5BA2\u60F3\u4E00\u676F\u98F2\u6599\tL\t\r\n10\t2\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u98F2\u6599\u6A5F\u5C31\u5728\u6536\u9280\u53F0\u7684\u5F8C\u65B9\uFF0C\\n\u98F2\u6599\u6A5F\u7684\u64CD\u4F5C\u65B9\u5F0F\u548C\u70F9\u98EA\u53F0\u4E00\u6A23\tL\t\r\n10\t3\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u88FD\u4F5C\u4E00\u676F\u98F2\u6599\u7D66\u9019\u4F4D\u9867\u5BA2\u5427!\tL\t\r\n11\t1\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u7CDF\u7CD5!\u9019\u4F4D\u9867\u5BA2\u7684\u5DF2\u7D93\u6C92\u4EC0\u9EBC\u8010\u5FC3\u4E86\uFF0C\\n\u8981\u662F\u9867\u5BA2\u8010\u5FC3\u70BA0\u5C31\u6703\u96E2\u958B\u9910\u5EF3\tL\t\r\n11\t2\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u4F7F\u7528\u89D2\u8272\u5361\u4F86\u56DE\u5FA9\u9867\u5BA2\u7684\u8010\u5FC3\u5427!\tL\t\r\n11\t3\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u9EDE\u64CA\u53F3\u4E0B\u65B9\u89D2\u8272\u5361\u4F7F\u7528\u5361\u7247\u80FD\u529B\tL\t\r\n12\t1\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u9867\u5BA2\u7684\u8010\u5FC3\u56DE\u5FA9\u4E86\tL\t\r\n12\t2\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u6BCF\u500B\u89D2\u8272\u5361\u90FD\u6709\u5C6C\u65BC\u81EA\u5DF1\u7684\u7368\u7279\u80FD\u529B\uFF0C\\n\u5728\u5C0D\u7684\u6642\u6A5F\u4F7F\u7528\u80FD\u8B93\u4F60\u61C9\u4ED8\u4E00\u4E9B\u7DCA\u6025\u60C5\u6CC1\tL\t\r\n13\t1\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u606D\u559C\u59B3\u5B78\u6703\u71DF\u696D\u7684\u57FA\u790E\u64CD\u4F5C\u4E86!\tL\t\r\n13\t2\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u90A3\u9EBC\u8B93\u6211\u5011\u9032\u5165\u5BE6\u6230\u5427!\tL\t\r\n13\t3\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u8A66\u8A66\u5728\u6B47\u696D\u524D\u76E1\u53EF\u80FD\u5730\u5B8C\u6210\u591A\u540D\u9867\u5BA2\u8A02\u55AE\u5427!\tL\t\r\n13_1\t1\t\u771F\u767D\tWhite_01\tWhite_DialogueBox_00\t\u9019\u662F\u600E\u9EBC\u56DE\u4E8B!\tR\t\r\n13_1\t2\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u9019\u662F!\u9019\u662F\u98DF\u6750\u6B63\u8655\u8B8A\u7570\u66B4\u8D70\tL\t\r\n13_1\t3\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u9677\u5165\u8B8A\u7570\u66B4\u8D70\u7684\u98DF\u6750\u6703\u8B8A\u5F97\u96E3\u4EE5\u6599\u7406\tL\t\r\n13_1\t4\t\u771F\u767D\tWhite_01\tWhite_DialogueBox_03\t\u96E3\u4EE5\u6599\u7406\uFF0C\u5225\u958B\u73A9\u7B11\u6211\u624D\u4E0D\u6703\u8F38\u7D66\u9019\u4E9B\u7121\u7406\u53D6\u9B27\u7684\u98DF\u6750\tR\t\r\n13_1\t5\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u90A3\u8981\u6CE8\u610F\uFF0C\u6709\u4E9B\u8B8A\u7570\u6703\u4F7F\u539F\u672C\u88FD\u4F5C\u6599\u7406\u7684\u908F\u8F2F\u6539\u8B8A\u3002\tL\t\r\n13_1\t6\t\u771F\u767D\tWhite_01\tWhite_DialogueBox_03\t\u6536\u5230\uFF0C\u770B\u6211\u600E\u9EBC\u6599\u7406\u6599\u7406\u4ED6\u5011\tR\t\r\n13_2\t1\t\u771F\u767D\tWhite_00\tWhite_DialogueBox_00\t\u6210\u529F\u4E86\tR\t\r\n13_2\t1\t\u7D05\u54B2\tHONGXIAO_02\tHONGXIAO_DialogueBox_00\t\u592A\u53B2\u5BB3\u4E86!
      \u6C92\u60F3\u5230\u771F\u767D\u4F60\u80FD\u6210\u529F\u6599\u7406\u9677\u5165\u8B8A\u7570\u66B4\u8D70\u7684\u98DF\u6750\tL\t\r\n13_2\t2\t\u771F\u767D\tWhite_00\tWhite_DialogueBox_00\t\u9019\u6C92\u4EC0\u9EBC\uFF0C\u96D6\u7136\u96E3\u7E8F\u4E86\u9EDE\uFF0C\\n\u4F46\u6211\u8AAA\u904E\u4E86\u6211\u624D\u4E0D\u6703\u8F38\u7D66\u9019\u4E9B\u7121\u7406\u53D6\u9B27\u7684\u98DF\u6750\tR\t\r\n13_2\t3\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u8B8A\u7570\u98DF\u6750\u96D6\u7136\u96E3\u6599\u7406\uFF0C\u4F46\u4E5F\u6703\u6FC0\u767C\u98DF\u6750\u7684\u6F5B\u80FD\tL\t\r\n13_2\t4\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u5C07\u8B8A\u7570\u98DF\u6750\u88FD\u6210\u7684\u6599\u7406\u7D66\u9867\u5BA2\u4E5F\u6703\u6709\u8F03\u597D\u7684\u50F9\u9322\u5594!\tL\t\r\n14\t1\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u770B\u6A23\u5B50\u70F9\u98EA\u53F0\u6C92\u6709\u80FD\u91CF\u4E86\tL\t\r\n14\t2\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u6C92\u6709\u80FD\u91CF\u7684\u70F9\u98EA\u53F0\u662F\u7121\u6CD5\u4F7F\u7528\u7684\tL\t\r\n14\t3\t\u7D05\u54B2\tHONGXIAO_01\tHONGXIAO_DialogueBox_00\t\u9019\u6642\u5C31\u9700\u8981\u5230\u51B0\u7BB1\u62FF\u88DC\u7D66\u56DE\u5FA9\u80FD\u91CF\tL\t\r\n14\t4\t\u7D05\u54B2\tHONGXIAO_00\tHONGXIAO_DialogueBox_00\t\u5230\u51B0\u7BB1\u524D\u6309\u4E0B\"
